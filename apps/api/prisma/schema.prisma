generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  timezone  String
  centerLat Float
  centerLng Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cities")
}

enum Role {
  user
  moderator
  admin
}

enum AccountStatus {
  active
  blocked
}

enum AuthProvider {
  password
}

model User {
  id         String        @id @default(cuid())
  role       Role          @default(user)
  status     AccountStatus @default(active)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  identities AuthIdentity[]

  @@map("users")
}

model AuthIdentity {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   AuthProvider
  identifier String
  secretHash String?
  verifiedAt DateTime?
  createdAt  DateTime     @default(now())

  @@unique([provider, identifier])
  @@index([userId])
  @@map("auth_identities")
}
