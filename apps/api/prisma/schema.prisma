generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  timezone  String
  centerLat Float
  centerLng Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cities")
}
