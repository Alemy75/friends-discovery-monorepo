# API
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=change-me-32-characters-minimum-xx
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
COOKIE_SECURE=false
APP_URL=http://localhost:5173

# Mail
MAIL_FROM=no-reply@friends.local

# Captcha
CAPTCHA_ENABLED=false
CAPTCHA_SECRET=

# PostgreSQL
POSTGRES_USER=friends
POSTGRES_PASSWORD=changeme
POSTGRES_DB=friends
# Default values target the docker-compose network (service hostnames).
# The API container reaches Postgres/Redis by service name on the compose network.
DATABASE_URL=postgresql://friends:changeme@postgres:5432/friends
REDIS_URL=redis://redis:6379

# --- Host-based development (running `npm run start:dev` on your machine,
# with the stack up via `docker compose up`) — use these instead:
# NOTE: compose publishes Postgres on host port 5433 (see docker-compose.yml).
# DATABASE_URL=postgresql://friends:changeme@localhost:5433/friends
# REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=changeme123
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=friends-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=changeme123
# Публичная база URL для отдачи фото (endpoint + bucket).
S3_PUBLIC_URL=http://localhost:9000/friends-media
S3_UPLOAD_MAX_BYTES=5242880
